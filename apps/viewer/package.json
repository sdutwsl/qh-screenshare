{
  "name": "@uos/viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main/main.js",
  "scripts": {
    "dev": "vite --port 5174",
    "dev:web": "VITE_PURE_WEB=1 vite --port 5174",
    "build": "vite build && tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "preview": "vite preview",
    "package": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@uos/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "~5.4.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
