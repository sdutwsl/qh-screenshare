{
  "name": "uos-screen-share",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,viewer,host -c blue,green,yellow \"pnpm dev:server\" \"pnpm dev:viewer\" \"pnpm dev:host\"",
    "dev:server": "pnpm --filter @uos/signaling-server dev",
    "dev:viewer": "pnpm --filter @uos/viewer dev",
    "dev:host": "pnpm --filter @uos/host dev",
    "build": "pnpm -r build",
    "lint": "eslint 'packages/**/*.ts' 'apps/**/*.ts' --ignore-pattern '**/dist/**'",
    "format": "prettier --write 'packages/**/*.ts' 'apps/**/*.ts' 'apps/**/*.html' 'apps/**/*.css'",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "~5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
